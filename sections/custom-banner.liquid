
<section class="banner" style="background-image: url({{ section.settings.bg_image | image_url }});">
    <div class="banner-content">
        <h1>{{ section.settings.heading }}</h1>
        <p>{{ section.settings.subtext }}</p>
        <a href="#" class="btn">{{ section.settings.button_text }}</a>
    </div>
</section>    

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "subtext", "label": "Subtext" },
    { "type": "text", "id": "button_text", "label": "Button Text" },
    { "type": "image_picker", "id": "bg_image", "label": "Background Image" }
  ]
}
{% endschema %}