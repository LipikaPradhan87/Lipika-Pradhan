 {{ 'custom.css' | asset_url | stylesheet_tag }}
<div class="grid">
  {% for i in (1..6) %}
  {% assign key = "product_" | append: i %}
  {% assign product_handle = section.settings[key] %}
  {% assign product = all_products[product_handle] %}
    
    {% if product %}
      <div class="product-card" data-product='{{ product | json | escape }}'>
      {% if product.featured_media %}
        <div class="image-wrapper">
          <img 
            src="{{ product.featured_media | image_url: width: 400 }}" 
            alt="{{ product.title }}" width="auto" height="auto"
          />

          <!-- ✅ PLUS BUTTON -->
          <button class="plus-btn">+</button>
        </div>
      {% endif %}
        <h3 style="margin-bottom: 0px">{{ product.title }}</h3>
        <p style="margin: 0">{{ product.price | money }}</p>

      </div>
    {% endif %}
  {% endfor %}
</div>
<div id="product-modal" class="modal">
  <div class="modal-content">

    <span id="close-modal" class="close-btn">X</span>

    <div class="modal-body">
      <div class="modal-left">
        <img id="modal-image" src="" alt="">
      </div>

      <div class="modal-right">
        <h2 id="modal-title"></h2>
        <p id="modal-price"></p>
        <div id="modal-description"></div>
        <div id="modal-variants"></div>
        <button id="add-to-cart" class="btn">Add to Cart</button>
      </div>
    </div>
  </div>
</div>

<script src="{{ 'custom.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Product Grid",
  "settings": [
    { "type": "product", "id": "product_1", "label": "Product 1" },
    { "type": "product", "id": "product_2", "label": "Product 2" },
    { "type": "product", "id": "product_3", "label": "Product 3" },
    { "type": "product", "id": "product_4", "label": "Product 4" },
    { "type": "product", "id": "product_5", "label": "Product 5" },
    { "type": "product", "id": "product_6", "label": "Product 6" }
  ]
}
{% endschema %}